# Golf booking credentials (REQUIRED)
GOLF_EMAIL=your-email@example.com
GOLF_PASSWORD=your-password-here

# Timezone for scheduling
TIMEZONE=America/Chicago

# How many days ahead to book
BOOKING_HORIZON_DAYS=30

# Fallback window when exact time unavailable (minutes)
FALLBACK_MINUTES=30

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Screenshot directory
SCREENSHOT_DIR=./screenshots

# Database path
DB_PATH=./data/bookings.db

# Set to true to run Playwright headless (no visible browser window).
# Default is false (visible) for interactive commands. Set true for automated/daemon runs.
# HEADLESS=true

# Hour of day (0–23, local time) at which the daily scheduler job fires.
# Default: 6 (06:00 local time). Change to 8 for 08:00, etc.
# SCHEDULER_HOUR=6

# Set to true to enable HTTPS using data/certs/cert.pem and data/certs/key.pem.
# Default is false (plain HTTP). Enable for external access over DuckDNS.
# HTTPS_ENABLED=true

# URL for the /api/ping endpoint on your Express server.
# When set, the GitLab Pages static site sends a beacon here so visits appear in /admin.
# Requires HTTPS_ENABLED=true on the Express server (mixed-content policy).
# PING_URL=https://fwbgaggle-schedule.duckdns.org:3002/api/ping
